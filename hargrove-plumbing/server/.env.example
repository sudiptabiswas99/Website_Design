# ── Hargrove & Sons booking server ───────────────────────────────
# Copy to `.env` and fill in. In development you can leave SMTP_* blank:
# the server spins up a free Ethereal test inbox and returns a preview
# link in the API response (no real email is delivered).

NODE_ENV=development
PORT=8787

# ── SMTP (required in production) ────────────────────────────────
# Gmail example: create an App Password (not your login password).
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-16-char-app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── Lead delivery ────────────────────────────────────────────────
# Where booking emails are sent, and the From identity shown to you.
BOOKING_TO=owner@your-real-email.com
BOOKING_FROM=Hargrove & Sons Website <no-reply@hargroveplumbing.com>

# ── Misc ─────────────────────────────────────────────────────────
# Comma-separate multiple origins, or use * to allow all.
CORS_ORIGIN=*
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MIN=10
