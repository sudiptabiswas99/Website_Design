# Apify — Lead scraping via Google Maps
# Get your token at: apify.com → Settings → Integrations
APIFY_TOKEN=your_apify_token_here

# Vercel — Site deployment (optional, needed for remote/SSH setups)
# Get your token at: vercel.com/account/tokens
# If not set, you must run `vercel login` instead
VERCEL_TOKEN=
